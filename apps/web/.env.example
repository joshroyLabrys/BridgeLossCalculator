# OpenAI — AI Summary Feature
# Auth priority: OPENAI_API_KEY > OPENAI_OAUTH_TOKEN > ~/.codex/auth.json
#
# For Vercel: set OPENAI_API_KEY in the Vercel dashboard
# For local dev: no env needed if you have ~/.codex/auth.json (run `codex login`)

# Standard Platform API key (required for Vercel)
# OPENAI_API_KEY=sk-...

# Or Codex OAuth token (optional, expires daily)
# OPENAI_OAUTH_TOKEN=eyJ...
